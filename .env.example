# Server Configuration
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# LLM Provider, supported values: openai, abacus
LLM_PROVIDER=openai

# OpenAI Configuration (only required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4.1-nano
OPENAI_TIMEOUT_MS=30000

# Abacus Configuration (only required when LLM_PROVIDER=abacus)
# ABACUS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ABACUS_MODEL=claude-3-7-sonnet-20250219
# ABACUS_TIMEOUT_MS=30000
